# Agora environment variables
# Copy to .env and fill in your values: cp .env.example .env

# EVM private key for the demo buyer wallet (hex, with or without 0x prefix)
# Fund this wallet with Base Sepolia USDC from https://faucet.circle.com/
BUYER_PRIVATE_KEY=

# Seller wallet address (receives payments)
SELLER_ADDRESS=

# USDC price per API call (human-readable, e.g. "0.001")
PRICE_USDC=0.001

# x402 facilitator URL
FACILITATOR_URL=https://x402.org/facilitator

# Public base URL (used in x402 402 responses)
BASE_URL=https://agora.steven-geller.com

# HMAC secret for MPP challenge IDs (change in production)
MPP_SECRET=

# Tempo RPC endpoint for MPP payment verification
TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz
